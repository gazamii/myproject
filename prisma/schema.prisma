// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
 
}

model Student { //학생 정보 저장
  id            Int      @id @default(autoincrement())
  department    String
  admissionYear Int
  currentYear   String
  careerGoal    String
  freeDay       String?
  preferredTime String?
  createdAt     DateTime @default(now())

  results       DiagnosisResult[]
}

model DiagnosisResult { //진단 결과 저장
  id                     Int      @id @default(autoincrement())
  studentId              Int
  totalCredits           Int
  majorRequiredCredits   Int
  majorElectiveCredits   Int
  generalCredits         Int

  passedTotal            Boolean
  passedMajorRequired    Boolean
  passedMajorElective    Boolean
  passedGeneral          Boolean

  부족Total              Int
  부족MajorRequired      Int
  부족MajorElective      Int
  부족General            Int

  createdAt              DateTime @default(now())

  student                Student @relation(fields: [studentId], references: [id])
}
